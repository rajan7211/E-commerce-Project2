{
  "compilerOptions": {
  
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "CommonJS",
    // "moduleResolution": "node",


    "rootDir": "./src",
    "outDir": "./dist",


    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

   
    "strict": true,
    "strictPropertyInitialization": false,  /* Entity fields ke liye */
    "noImplicitAny": true,
    "strictNullChecks": true,


    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": true,


    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}





















